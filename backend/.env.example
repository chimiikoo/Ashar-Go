# ============================================================
#  Backend ENV — скопируй в Render → Environment Variables
# ============================================================

# Database (Render PostgreSQL или Supabase)
DATABASE_URL=postgresql://user:password@host:5432/ashar_go

# JWT
JWT_SECRET=super-secret-change-me-in-production-min-32chars

# Server
PORT=4000
NODE_ENV=production

# Frontend URL (для CORS — замени на реальный Netlify URL)
FRONTEND_URL=https://ashar-go.netlify.app

# Email (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16char-app-password

# Хранилище файлов (Cloudinary — бесплатно, работает на Render)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Максимальный размер видео (3 мин ≈ 150MB)
MAX_VIDEO_SIZE_MB=150
MAX_IMAGE_SIZE_MB=10
MAX_PHOTOS_COUNT=5
