# ─── Node ───────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Next.js ────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/.env.local
frontend/.env.production.local

# ─── Build output ───────────────────────────────────────────────────
frontend/dist/
backend/dist/

# ─── Environment files (sensitive) ──────────────────────────────────
