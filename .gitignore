.DS_Store
Thumbs.db
desktop.ini

# ─── IDEs ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Logs ───────────────────────────────────────────────────────────
*.log
logs/
